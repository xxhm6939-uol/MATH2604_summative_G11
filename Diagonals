import static java.lang.Math.*;

class Diagonals
{
    public static double[] inverse(double[] a)
    {
        if (a == null)
        {
            return null;
        }

        int n = a.length;

        if (n == 0)
        {
            return new double[0];
        }

        double[] result = new double[n];

        for (int i = 0; i < n; i++)
        {
            result[i] = 1.0 /a[i];
        }

        return result;
    }
}